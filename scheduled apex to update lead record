public class DailyLeadProcessor implements Schedulable {

    public void execute(SchedulableContext ctx) {
        // Find the first 200 Lead records with a blank LeadSource field
        List<Lead> leads = [
            SELECT Id, LeadSource 
            FROM Lead 
            WHERE LeadSource = null 
            LIMIT 200
        ];
        
        // Update their LeadSource value to 'Dreamforce'
        for (Lead l : leads) {
            l.LeadSource = 'Dreamforce';
        }
        
        // Commit changes to the database
        if (leads.size() > 0) {
            update leads;
        }
    }
}

//test code
@isTest
public class DailyLeadProcessorTest {

    // Seconds Minutes Hours Day_of_month Month Day_of_week optional_year
    public static String CRON_EXP = '0 0 0 15 3 ? 2040';

    @isTest
    static void testScheduledJob() {
        // Insert 200 Lead records with blank LeadSource fields
        List<Lead> testLeads = new List<Lead>();
        for (Integer i = 0; i < 200; i++) {
            testLeads.add(new Lead(
                FirstName = 'TestFirst' + i,
                LastName = 'TestLast' + i,
                Company = 'TestCompany' + i,
                LeadSource = null
            ));
        }
        insert testLeads;

        // Schedule the job inside startTest and stopTest blocks
        Test.startTest();
        String jobId = System.schedule('ScheduledApexTest', CRON_EXP, new DailyLeadProcessor());
        Test.stopTest(); // Forces the scheduled job to run immediately during the test execution

        // Verify that all 200 records were updated properly
        List<Lead> updatedLeads = [SELECT Id FROM Lead WHERE LeadSource = 'Dreamforce'];
        System.assertEquals(200, updatedLeads.size(), 'All 200 Lead records should have LeadSource updated to Dreamforce');
    }
}
