public class AddPrimaryContact implements Queueable {
    
    private Contact contactTemplate;
    private String stateAbbreviation;
    
    // Constructor accepting the Contact sObject and the State abbreviation string
    public AddPrimaryContact(Contact c, String state) {
        this.contactTemplate = c;
        this.stateAbbreviation = state;
    }
    
    public void execute(QueueableContext context) {
        // Query for a maximum of 200 Accounts matching the specified BillingState
        List<Account> accounts = [
            SELECT Id, BillingState 
            FROM Account 
            WHERE BillingState = :stateAbbreviation 
            LIMIT 200
        ];
        
        List<Contact> contactsToInsert = new List<Contact>();
        
        for (Account acc : accounts) {
            // Clone the contact template (false parameters ensure it creates a completely fresh record)
            Contact clonedContact = contactTemplate.clone(false, false, false, false);
            clonedContact.AccountId = acc.Id; // Link it to the current account
            contactsToInsert.add(clonedContact);
        }
        
        // Insert all cloned contacts in bulk
        if (contactsToInsert.size() > 0) {
            insert contactsToInsert;
        }
    }
}

@isTest
public class AddPrimaryContactTest {

    @isTest
    static void testQueueableJob() {
        List<Account> testAccounts = new List<Account>();
        
        // Insert 50 Account records for BillingState NY
        for (Integer i = 0; i < 50; i++) {
            testAccounts.add(new Account(Name = 'NY Account ' + i, BillingState = 'NY'));
        }
        
        // Insert 50 Account records for BillingState CA
        for (Integer i = 0; i < 50; i++) {
            testAccounts.add(new Account(Name = 'CA Account ' + i, BillingState = 'CA'));
        }
        insert testAccounts;
        
        // Create a template Contact record
        Contact templateContact = new Contact(FirstName = 'Primary', LastName = 'Contact');
        
        // Create an instance of the AddPrimaryContact Queueable class targeting 'CA'
        AddPrimaryContact job = new AddPrimaryContact(templateContact, 'CA');
        
        // Enqueue the job inside startTest and stopTest to force synchronous execution during the test
        Test.startTest();
        System.enqueueJob(job);
        Test.stopTest();
        
        // Assert that a Contact record was inserted for each of the 50 Accounts with BillingState of CA
        List<Contact> insertedContacts = [SELECT Id FROM Contact WHERE Account.BillingState = 'CA'];
        System.assertEquals(50, insertedContacts.size(), 'Exactly 50 contacts should be inserted for CA accounts');
    }
}
