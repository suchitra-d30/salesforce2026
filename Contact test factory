public class RandomContactFactory {

    public static List<Contact> generateRandomContacts(Integer numContacts, String lastName) {
        List<Contact> contacts = new List<Contact>();
        
        // Loop to generate the requested number of contacts
        for (Integer i = 0; i < numContacts; i++) {
            // Set unique first name like Test 0, Test 1, etc., and the shared last name
            Contact c = new Contact(FirstName = 'Test ' + i, LastName = lastName);
            contacts.add(c);
        }
        
        // Return the list without saving them to the database
        return contacts;
    }
}
